</div>
<div className="week-mini">
{weekDates.map((d, i) => {
const dayLabel = [“M”,“T”,“W”,“T”,“F”,“S”,“S”][new Date(d).getDay() === 0 ? 6 : new Date(d).getDay() - 1];
const dayLogs = logs[d] || {};
const done = goals.filter(g => {
const v = dayLogs[g.id];
if (g.type === “binary” || g.type === “streak”) return v === 1 || v === true;
if (g.type === “quantitative”) return v && parseFloat(v) >= parseFloat(g.target_value || 1);
return false;
}).length;
const isToday = d === today;
const isFuture = d > today;
let dotClass = “streak-dot missed”;
if (isFuture) dotClass = “streak-dot future”;
else if (done > 0 && done >= goals.length * 0.5) dotClass = “streak-dot done”;
return (
<div key={d} className={`week-day ${isToday ? "today" : ""}`}>
<span className="week-day-label">{dayLabel}</span>
<div className={dotClass} />
</div>
);
})}
</div>
</div>

